{
  "name": "tanstack_start_ts",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "node --input-type=module -e \"import { spawn } from 'node:child_process'; const a = spawn('npm.cmd', ['--prefix','server','run','start:dev'], { stdio: 'inherit', shell: true }); const b = spawn('npm.cmd', ['run','dev:frontend'], { stdio: 'inherit', shell: true }); const onExit = (code) => process.exit(code ?? 0); a.on('exit', onExit); b.on('exit', onExit);\"",
    "dev:frontend": "vite dev --host 127.0.0.1 --port 5173",
    "dev:frontend:lan": "vite dev --host 0.0.0.0 --port 5173",
    "dev:server": "npm.cmd --prefix server run start:dev",
    "build": "vite build",
    "build:mobile": "node --input-type=module -e \"import { spawn } from 'node:child_process'; const p = spawn('npm.cmd', ['run','build'], { stdio: 'inherit', shell: true, env: { ...process.env, CAPACITOR: 'true' } }); p.on('exit', (code) => process.exit(code ?? 0));\"",
    "cap:add:android": "npx.cmd cap add android",
    "cap:add:ios": "npx.cmd cap add ios",
    "cap:sync": "npx.cmd cap sync",
    "cap:sync:android": "npx.cmd cap sync android",
    "cap:open:android": "npx.cmd cap open android",
    "cap:open:ios": "npx.cmd cap open ios",
    "build:dev": "vite build --mode development",
    "preview": "vite preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f"
  },
  "dependencies": {
